# TEMPLATE — do NOT put real values here or commit a real secrets.toml (it is .gitignored).
# Paste the real content into Streamlit Community Cloud → App → Settings → Secrets.
#
# TWO things go in Secrets:
#   1. app_password — the shared login password for this public app (fail-closed: if missing on the
#      cloud, the app blocks everyone rather than opening). MUST be above the [gcp_service_account] header.
#   2. [gcp_service_account] — a JSON key for the SCOPED, read-only marketing service account
#      (marketing-dashboard@supertri-reg-analytics.iam.gserviceaccount.com), which can read ONLY the
#      revenue-free supertri_marketing.* views. Generate the block from the key JSON with:
#        python3 -c 'import json,sys; d=json.load(open(sys.argv[1]))
#        ks=["type","project_id","private_key_id","private_key","client_email","client_id","auth_uri","token_uri","auth_provider_x509_cert_url","client_x509_cert_url"]
#        print("[gcp_service_account]"); [print(f"{k} = {json.dumps(d[k])}") for k in ks]' /path/to/marketing-key.json

app_password = "REPLACE_WITH_A_STRONG_SHARED_PASSWORD"

[gcp_service_account]
type = "service_account"
project_id = "supertri-reg-analytics"
private_key_id = "REPLACE_ME"
private_key = "-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
client_email = "marketing-dashboard@supertri-reg-analytics.iam.gserviceaccount.com"
client_id = "REPLACE_ME"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "REPLACE_ME"
